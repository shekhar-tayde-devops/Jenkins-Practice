pipeline {
    agent {
        docker {
            image 'shekhartaydde/node-shekhar-docker-agent:v1'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        NPM_CONFIG_CACHE = "${WORKSPACE}/.npm"
        SONAR_USER_HOME = "${WORKSPACE}/.sonar"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/shekhar-tayde-devops/Jenkins-Practice'
            }
        }

        stage('Build and Test') {
            steps {
                sh 'npm install'
            }
        }

        stage('Static Code Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {

                    sh """
                        npx sonar-scanner \
                        -Dsonar.projectKey=test-app \
                        -Dsonar.sources=. \
                        -Dsonar.host.url=http://65.0.75.224:9000 \
                        -Dsonar.login=${SONAR_AUTH_TOKEN}
                    """
                }
            }
        }

        stage('Build and Push Docker Image') {
            environment {
                HOME = "${WORKSPACE}"
                DOCKER_IMAGE = "shekhartaydde/test-app:${BUILD_NUMBER}"
                REGISTRY_CREDENTIALS = credentials('docker-cred')
            }
            steps {
                script {
                    sh "docker build -t ${DOCKER_IMAGE} ."
                    def dockerImage = docker.image("${DOCKER_IMAGE}")
                    docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
                        dockerImage.push()
                    }
                }
            }
        }
    }
}
