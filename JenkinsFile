pipeline {
    agent {
        docker {
            image 'node:18'
        }
    }

    stages {
        stage('Checkout') {
            steps {
                //git branch: 'main', url: 'https://github.com/shekhar-tayde-devops/Jenkins-Practice'
            }
        }

        stage('Build and Test') {
            steps {
                sh 'npm install'
            }
        }

        stage('Static Code Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_TOKEN')]) {
                    sh '''
                        npm install -g sonar-scanner
                        sonar-scanner \
                            -Dsonar.projectKey=test-app \
                            -Dsonar.sources=. \
                            -Dsonar.host.url=http://65.0.75.224:9000 \
                            -Dsonar.login=$SONAR_TOKEN
                    '''
                }
            }
        }
    }
}
