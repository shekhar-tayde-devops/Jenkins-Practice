pipeline {
    agent {
        docker {
            image 'shekhartaydde/node-shekhar-docker-agent:v1'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    stages {

        stage('Check Node Version') {
            steps {
                sh 'node -v'
            }
        }

        stage('Check NPM Version') {
            steps {
                sh 'npm -v'
            }
        }

        stage('Check Docker Version') {
            steps {
                sh 'docker --version'
            }
        }

    }
}